{
  "name": "crushflow-v2",
  "version": "2.0.0",
  "description": "CrushFlow V2 — Sistema ERP Multi-departamento",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev":   "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:schema": "mysql -u $DB_USER -p$DB_PASSWORD $DB_NAME < scripts/01-schema.sql",
    "db:seed":   "mysql -u $DB_USER -p$DB_PASSWORD $DB_NAME < scripts/02-seed.sql"
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "cors":               "^2.8.5",
    "dotenv":             "^16.3.1",
    "express":            "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "helmet":             "^7.1.0",
    "jsonwebtoken":       "^9.0.2",
    "mysql2":             "^3.6.5",
    "nodemailer":         "^8.0.1",
    "pino":               "^8.17.1",
    "pino-http":          "^8.5.1",
    "zod":                "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs":    "^2.4.6",
    "@types/cors":        "^2.8.17",
    "@types/express":     "^4.17.21",
    "@types/jsonwebtoken":"^9.0.5",
    "@types/node":        "^20.10.4",
    "@types/nodemailer":  "^6.4.14",
    "pino-pretty":        "^13.1.3",
    "ts-node-dev":        "^2.0.0",
    "typescript":         "^5.3.3"
  }
}
